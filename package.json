{
  "name": "elms",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "npm run electron:dev",
    "all": "npm run electron:dev",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:elms": "node dist/elms/server/server.mjs",
    "electron:dev": "concurrently \"npm run start\" \"wait-on http://localhost:4200 && electron .\"",
    "bundle:backend": "ncc build src/backend/server.js -o dist/backend",
    "electron:build": "npm run bundle:backend && ng build && electron-builder build --win --x64"
  },
  "build": {
    "appId": "com.elms.app",
    "productName": "ELMS",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "dist/**/*"
    ],
    "files": [
      "electron/**/*",
      "src/backend/**/*",
      "dist/**/*",
      "uploads",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/backend",
        "to": "backend"
      },
      {
        "from": "uploads",
        "to": "uploads"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ELMS"
    }
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/service-worker": "^21.0.0",
    "@angular/ssr": "^21.0.3",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.5.1",
    "cors": "^2.8.6",
    "dexie": "^4.3.0",
    "express": "^5.2.1",
    "mongoose": "^9.2.4",
    "multer": "^2.1.1",
    "node": "^25.9.0",
    "nodemailer": "^8.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.3",
    "@angular/cli": "^21.0.3",
    "@angular/compiler-cli": "^21.0.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@vercel/ncc": "^0.38.4",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "jsdom": "^27.1.0",
    "png-to-ico": "^3.0.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "wait-on": "^9.0.4"
  }
}
